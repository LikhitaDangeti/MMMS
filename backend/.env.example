# Copy to .env (or set these in your environment) to configure the backend.
# Leave MONGODB_URI unset to use the local lowdb JSON store (default).

# --- Use MongoDB / MongoDB Atlas in production ---
# Local Docker:   mongodb://localhost:27017
# Atlas:          mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net
# MONGODB_DB=mmms

# --- Use Microsoft SQL Server ---
# Format: Server=localhost,1433;Database=mmms;User Id=sa;Password=YourPassword;Encrypt=true;TrustServerCertificate=true;
# SQLSERVER_URI=Server=localhost,1433;Database=mmms;User Id=sa;Password=YourPassword;Encrypt=true;TrustServerCertificate=true;

# API port (default 4000)
# PORT=4000
